# =========================
# KORE Web — variáveis
# =========================
# Copie este arquivo para `.env.local` e preencha os valores.
# Nunca comite .env.local — está no .gitignore.

# --- Supabase ---
# Public (browser + server)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Server only (webhooks, jobs admin). Nunca expor ao cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- Stripe Connect ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_PLATFORM_FEE_BPS=1000   # 10.00% (10000 = 100%)

# --- n8n ---
N8N_WEBHOOK_SECRET=please-rotate-me

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
